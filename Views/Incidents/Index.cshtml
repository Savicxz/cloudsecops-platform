@model IEnumerable<CloudSecOps.Models.Incident>

@{
    ViewData["Title"] = "Security Incidents";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Security Incidents</h1>
        <p class="text-muted mb-0">
            Track reported cybersecurity incidents, severity levels, investigation status, and reporter details.
        </p>
    </div>

    <a asp-action="Create" class="btn btn-primary">
        Report New Incident
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-dark text-white">
        Incident Register
    </div>

    <div class="card-body p-0">
        <table class="table table-bordered table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Severity</th>
                    <th>Status</th>
                    <th>Description</th>
                    <th>Reported By</th>
                    <th>Created At</th>
                    <th style="width: 180px;">Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            No incidents have been reported yet.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">
                                @item.Title
                            </td>

                            <td>
                                @item.Category
                            </td>

                            <td>
                                @if (item.Severity == "Critical")
                                {
                                    <span class="badge bg-danger">Critical</span>
                                }
                                else if (item.Severity == "High")
                                {
                                    <span class="badge bg-warning text-dark">High</span>
                                }
                                else if (item.Severity == "Medium")
                                {
                                    <span class="badge bg-info text-dark">Medium</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Low</span>
                                }
                            </td>

                            <td>
                                @if (item.Status == "Open")
                                {
                                    <span class="badge bg-primary">Open</span>
                                }
                                else if (item.Status == "Investigating")
                                {
                                    <span class="badge bg-warning text-dark">Investigating</span>
                                }
                                else if (item.Status == "Resolved")
                                {
                                    <span class="badge bg-success">Resolved</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Status</span>
                                }
                            </td>

                            <td>
                                @item.Description
                            </td>

                            <td>
                                @item.ReportedBy
                            </td>

                            <td>
                                @item.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC
                            </td>

                            <td>
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary">Details</a>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">Delete</a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>