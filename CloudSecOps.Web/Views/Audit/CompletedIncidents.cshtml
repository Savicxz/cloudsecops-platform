@model IReadOnlyList<CloudSecOps.Web.Models.Incidents.Incident>

@{
    ViewData["Title"] = "Completed Incidents";
}

<section class="cso-page-header">
    <div>
        <h1>Completed Incidents Review</h1>
        <p>Read-only review of incidents closed by the security team.</p>
    </div>
    <a class="btn-ghost" asp-action="Index">Back to Audit</a>
</section>

<section class="cso-panel">
    <table class="cso-table">
        <thead>
            <tr><th>Title</th><th>Category</th><th>Severity</th><th>Status</th><th>Closed</th></tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="5"><div class="cso-empty-state">No closed incidents are available for audit review.</div></td></tr>
            }
            else
            {
                @foreach (var incident in Model)
                {
                    <tr>
                        <td>@incident.Title</td>
                        <td>@incident.Category</td>
                        <td><span class="risk-pill @incident.Severity.ToString().ToLowerInvariant()">@incident.Severity</span></td>
                        <td><span class="status-pill">@incident.Status</span></td>
                        <td>@((incident.ClosedAt ?? incident.UpdatedAt ?? incident.CreatedAt).ToString("dd MMM yyyy"))</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</section>
