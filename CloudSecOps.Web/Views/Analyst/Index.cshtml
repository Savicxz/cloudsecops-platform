@model CloudSecOps.Web.ViewModels.Analyst.AnalystDashboardViewModel

@{
    ViewData["Title"] = "Security Analyst";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="h3 mb-1">Security Analyst Workspace</h1>
        <p class="text-muted mb-0">Review assigned incidents, high severity incidents, assets, and vulnerabilities.</p>
    </div>
    <a class="btn btn-outline-primary" asp-controller="Incidents" asp-action="Index">All Incidents</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <span class="text-muted small text-uppercase">Open Incidents</span>
                <div class="display-6 fw-semibold">@Model.OpenIncidentCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <span class="text-muted small text-uppercase">High Severity</span>
                <div class="display-6 fw-semibold">@Model.HighSeverityIncidentCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <span class="text-muted small text-uppercase">Active Assets</span>
                <div class="display-6 fw-semibold">@Model.AssetCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card h-100">
            <div class="card-body">
                <span class="text-muted small text-uppercase">High Risk Vulnerabilities</span>
                <div class="display-6 fw-semibold">@Model.HighSeverityVulnerabilityCount</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">Assigned Open Incidents</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Severity</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.AssignedOpenIncidents.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="text-muted">No assigned open incidents.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var incident in Model.AssignedOpenIncidents)
                            {
                                <tr>
                                    <td>@incident.Title</td>
                                    <td>@incident.Severity</td>
                                    <td>@incident.Status</td>
                                    <td>
                                        <a asp-action="IncidentDetails" asp-route-id="@incident.Id">Review</a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header fw-semibold">High Severity Incidents</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Title</th>
                            <th>Severity</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.HighSeverityIncidents.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="text-muted">No high severity open incidents.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var incident in Model.HighSeverityIncidents)
                            {
                                <tr>
                                    <td>@incident.Title</td>
                                    <td>@incident.Severity</td>
                                    <td>@incident.Status</td>
                                    <td>
                                        <a asp-action="IncidentDetails" asp-route-id="@incident.Id">Review</a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
