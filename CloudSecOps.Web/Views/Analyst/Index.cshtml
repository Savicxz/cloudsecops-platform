@model CloudSecOps.Web.ViewModels.Analyst.AnalystDashboardViewModel

@{
    ViewData["Title"] = "Security Analyst";
}

<section class="cso-page-header">
    <div>
        <p>Security Analyst</p>
        <h1>Security Analyst Workspace</h1>
        <span>Review assigned incidents, high severity incidents, assets, and vulnerabilities.</span>
    </div>
    <a class="btn-primary-app" asp-controller="Incidents" asp-action="Index">All Incidents</a>
</section>

<section class="metric-grid">
    <article class="metric-card">
        <span>Open Incidents</span>
        <strong>@Model.OpenIncidentCount</strong>
    </article>
    <article class="metric-card">
        <span>Open Reports</span>
        <strong>@Model.OpenIncidentReportCount</strong>
    </article>
    <article class="metric-card">
        <span>High Severity</span>
        <strong>@Model.HighSeverityIncidentCount</strong>
    </article>
    <article class="metric-card">
        <span>Active Assets</span>
        <strong>@Model.AssetCount</strong>
    </article>
    <article class="metric-card">
        <span>High Risk Vulnerabilities</span>
        <strong>@Model.HighSeverityVulnerabilityCount</strong>
    </article>
</section>

<section class="soc-grid">
    <article class="cso-panel">
        <h2>Open Incidents</h2>
        <table class="cso-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Severity</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.OpenIncidents.Count == 0)
                {
                    <tr><td colspan="4"><div class="cso-empty-state">No open incidents.</div></td></tr>
                }
                else
                {
                    @foreach (var incident in Model.OpenIncidents)
                    {
                        <tr>
                            <td>@incident.Title</td>
                            <td><span class="risk-pill @incident.Severity.ToString().ToLowerInvariant()">@incident.Severity</span></td>
                            <td><span class="status-pill">@incident.Status</span></td>
                            <td><a class="table-action" asp-action="IncidentDetails" asp-route-id="@incident.Id">Review</a></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </article>

    <article class="cso-panel">
        <h2>Assigned Open Incidents</h2>
        <table class="cso-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Severity</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.AssignedOpenIncidents.Count == 0)
                {
                    <tr><td colspan="4"><div class="cso-empty-state">No assigned open incidents.</div></td></tr>
                }
                else
                {
                    @foreach (var incident in Model.AssignedOpenIncidents)
                    {
                        <tr>
                            <td>@incident.Title</td>
                            <td><span class="risk-pill @incident.Severity.ToString().ToLowerInvariant()">@incident.Severity</span></td>
                            <td><span class="status-pill">@incident.Status</span></td>
                            <td><a class="table-action" asp-action="IncidentDetails" asp-route-id="@incident.Id">Review</a></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </article>

    <article class="cso-panel">
        <h2>High Severity Incidents</h2>
        <table class="cso-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Severity</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.HighSeverityIncidents.Count == 0)
                {
                    <tr><td colspan="4"><div class="cso-empty-state">No high severity open incidents.</div></td></tr>
                }
                else
                {
                    @foreach (var incident in Model.HighSeverityIncidents)
                    {
                        <tr>
                            <td>@incident.Title</td>
                            <td><span class="risk-pill @incident.Severity.ToString().ToLowerInvariant()">@incident.Severity</span></td>
                            <td><span class="status-pill">@incident.Status</span></td>
                            <td><a class="table-action" asp-action="IncidentDetails" asp-route-id="@incident.Id">Review</a></td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </article>
</section>

<section class="cso-panel">
    <h2>Recent Incident Reports</h2>
    <table class="cso-table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Severity</th>
                <th>Status</th>
                <th>Reported</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.RecentIncidentReports.Count == 0)
            {
                <tr>
                    <td colspan="5">
                        <div class="cso-empty-state">No reporter-submitted incident reports yet.</div>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var report in Model.RecentIncidentReports)
                {
                    <tr>
                        <td>@report.Title</td>
                        <td><span class="risk-pill @report.Severity.ToLowerInvariant()">@report.Severity</span></td>
                        <td><span class="status-pill">@report.Status</span></td>
                        <td>@report.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td><a class="table-action" asp-action="IncidentReportDetails" asp-route-id="@report.Id">Review</a></td>
                    </tr>
                }
            }
        </tbody>
    </table>
</section>
