@model CloudSecOps.Web.ViewModels.Analyst.AnalystIncidentReviewViewModel
@using CloudSecOps.Web.Models.Enums

@{
    ViewData["Title"] = "Analyst Incident Review";
}

<section class="cso-page-header">
    <div>
        <p>Security Analyst</p>
        <h1>@Model.Incident.Title</h1>
        <span>Review incident details and update the defensive response status.</span>
    </div>
    <a class="btn-ghost" asp-action="Index">Back to Analyst Dashboard</a>
</section>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <section class="cso-panel">
        <span class="status-pill active">@statusMessage</span>
    </section>
}

<section class="soc-grid">
    <article class="cso-panel detail-grid">
        <div class="detail-wide">
            <span>Title</span>
            <strong>@Model.Incident.Title</strong>
        </div>
        <div>
            <span>Category</span>
            <strong>@Model.Incident.Category</strong>
        </div>
        <div>
            <span>Severity</span>
            <strong><span class="risk-pill @Model.Incident.Severity.ToString().ToLowerInvariant()">@Model.Incident.Severity</span></strong>
        </div>
        <div>
            <span>Status</span>
            <strong><span class="status-pill">@Model.Incident.Status</span></strong>
        </div>
        <div>
            <span>Asset</span>
            <strong>@Model.Incident.RelatedAssetName</strong>
        </div>
        <div>
            <span>Assigned To</span>
            <strong>@Model.Incident.AssignedToName</strong>
        </div>
        <div>
            <span>Created</span>
            <strong>@Model.Incident.CreatedAt.ToString("dd MMM yyyy hh:mm tt")</strong>
        </div>
        <div class="detail-wide">
            <span>Description</span>
            <p>@Model.Incident.Description</p>
        </div>
    </article>

    <aside class="cso-panel cso-form">
        <h2>Update Status</h2>
        <form asp-action="UpdateIncidentStatus" method="post">
            <input type="hidden" name="id" value="@Model.Incident.Id" />
            <div class="mb-3">
                <label class="form-label" for="newStatus">Status</label>
                <select asp-for="NewStatus" class="form-select" name="newStatus" asp-items="Html.GetEnumSelectList<IncidentStatus>()"></select>
            </div>
            <div class="mb-3">
                <label class="form-label" for="investigationNote">Investigation Notes</label>
                <textarea class="form-control" id="investigationNote" name="investigationNote" rows="5" placeholder="Add defensive investigation notes"></textarea>
            </div>
            <button class="btn-primary-app" type="submit">Save Review Update</button>
        </form>
    </aside>
</section>

<section class="cso-panel">
    <h2>Investigation Timeline</h2>
    @if (Model.Incident.Updates.Count == 0)
    {
        <div class="cso-empty-state">No investigation notes or status changes yet.</div>
    }
    else
    {
        <ul class="timeline-list">
            @foreach (var update in Model.Incident.Updates)
            {
                <li>@update</li>
            }
        </ul>
    }
</section>
