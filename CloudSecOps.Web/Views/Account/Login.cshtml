@model CloudSecOps.Web.ViewModels.Account.LoginViewModel

@{
    ViewData["Title"] = "Sign In";
}

<section class="login-stage">
    <div class="login-card">
        <p>CloudSecOps Command</p>
        <h1>Sign In</h1>

        <form asp-action="Login" method="post" class="cso-form">
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" autocomplete="username" placeholder="admin@cloudsecops.local" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" autocomplete="current-password" placeholder="CloudSecOps@123" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-primary-app login-submit">Sign In</button>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
