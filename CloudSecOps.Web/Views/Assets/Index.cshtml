@model IReadOnlyList<CloudSecOps.Web.ViewModels.Assets.AssetListItemViewModel>

@{
    ViewData["Title"] = "Assets";
}

<div class="cso-page-header">
    <div>
        <h1>Assets</h1>
        <p>Track protected systems, owners, environments, and criticality.</p>
    </div>
    <a class="btn-primary-app" asp-action="Create">Add Asset</a>
</div>

<section class="cso-panel">
    <table class="cso-table">
        <thead>
            <tr><th>Name</th><th>Type</th><th>Environment</th><th>Criticality</th><th>Status</th><th></th></tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="6"><div class="cso-empty-state">No assets have been added yet.</div></td></tr>
            }
            else
            {
                @foreach (var asset in Model)
                {
                    <tr>
                        <td>@asset.Name</td>
                        <td>@asset.AssetType</td>
                        <td>@asset.Environment</td>
                        <td><span class="risk-pill @asset.Criticality.ToString().ToLowerInvariant()">@asset.Criticality</span></td>
                        <td><span class="status-pill">@asset.Status</span></td>
                        <td>
                            <a class="table-action" asp-action="Details" asp-route-id="@asset.Id">View</a>
                            <a class="table-action" asp-action="Edit" asp-route-id="@asset.Id">Edit</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</section>
