@model IReadOnlyList<CloudSecOps.Web.ViewModels.Incidents.IncidentListItemViewModel>

@{
    ViewData["Title"] = "Incidents";
}

<section class="cso-page-header">
    <div>
        <p>Operational Hub</p>
        <h1>Incidents</h1>
        <span>Coordinate defensive incident reporting, triage, assignment, and closure.</span>
    </div>
    <a class="btn-primary-app" asp-action="Create">Report Incident</a>
</section>

<section class="cso-panel">
    <table class="cso-table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Category</th>
                <th>Severity</th>
                <th>Status</th>
                <th>Created</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="6"><div class="cso-empty-state">No incidents have been recorded yet.</div></td>
                </tr>
            }
            else
            {
                @foreach (var incident in Model)
                {
                    <tr>
                        <td>@incident.Title</td>
                        <td>@incident.Category</td>
                        <td><span class="risk-pill @incident.Severity.ToString().ToLowerInvariant()">@incident.Severity</span></td>
                        <td><span class="status-pill">@incident.Status</span></td>
                        <td>@incident.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            <a class="table-action" asp-action="Details" asp-route-id="@incident.Id">View</a>
                            <a class="table-action" asp-action="Edit" asp-route-id="@incident.Id">Edit</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</section>
