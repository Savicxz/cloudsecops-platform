@model IReadOnlyList<CloudSecOps.Web.ViewModels.Incidents.IncidentListItemViewModel>

@{
    ViewData["Title"] = "Incidents";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1">Incidents</h1>
        <p class="text-muted mb-0">Coordinate defensive incident reporting, triage, assignment, and closure.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Report Incident</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Severity</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-muted">No incidents yet. Placeholder list for Task 1.</td>
                    </tr>
                }
                else
                {
                    @foreach (var incident in Model)
                    {
                        <tr>
                            <td>@incident.Title</td>
                            <td>@incident.Category</td>
                            <td>@incident.Severity</td>
                            <td>@incident.Status</td>
                            <td>@incident.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>
                                <a asp-controller="Analyst" asp-action="IncidentDetails" asp-route-id="@incident.Id">Review</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
