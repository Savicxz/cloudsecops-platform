@model CloudSecOps.Web.ViewModels.Incidents.IncidentDetailsViewModel

@{
    ViewData["Title"] = "Incident Details";
}

<section class="cso-page-header">
    <div>
        <p>Operational Hub</p>
        <h1>@Model.Title</h1>
        <span>Incident details for Security Analyst review.</span>
    </div>
    <a class="btn-ghost" asp-action="Index">Back to Incidents</a>
</section>

<section class="cso-panel detail-grid">
    <div>
        <span>Status</span>
        <strong><span class="status-pill">@Model.Status</span></strong>
    </div>
    <div>
        <span>Category</span>
        <strong>@Model.Category</strong>
    </div>
    <div>
        <span>Severity</span>
        <strong><span class="risk-pill @Model.Severity.ToString().ToLowerInvariant()">@Model.Severity</span></strong>
    </div>
    <div>
        <span>Asset</span>
        <strong>@Model.RelatedAssetName</strong>
    </div>
    <div>
        <span>Assigned To</span>
        <strong>@Model.AssignedToName</strong>
    </div>
    <div>
        <span>Created</span>
        <strong>@Model.CreatedAt.ToString("dd MMM yyyy hh:mm tt")</strong>
    </div>
    <div class="detail-wide">
        <span>Description</span>
        <p>@Model.Description</p>
    </div>
</section>

<section class="cso-panel">
    <h2>Investigation Timeline</h2>
    @if (Model.Updates.Count == 0)
    {
        <div class="cso-empty-state">No analyst updates have been recorded yet.</div>
    }
    else
    {
        <ul class="timeline-list">
            @foreach (var update in Model.Updates)
            {
                <li>@update</li>
            }
        </ul>
    }
</section>
