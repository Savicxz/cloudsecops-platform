@{
    ViewData["Title"] = "Reporter";
}

<div class="cso-page-header">
    <div>
        <h1>Reporter Dashboard</h1>
        <p>Create draft reports, submit them for analyst review, and track status.</p>
    </div>
</div>

<section class="role-card-grid">
    <a class="cso-panel action-panel" asp-controller="Reporter" asp-action="SubmitReport">
        <h2>Submit Report</h2>
        <p>Create a new report as a draft or submit it for review.</p>
    </a>
    <a class="cso-panel action-panel" asp-controller="Reporter" asp-action="MyReports">
        <h2>My Reports</h2>
        <p>Track reports submitted by the signed-in reporter.</p>
    </a>
</section>
