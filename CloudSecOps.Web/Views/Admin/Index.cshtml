@model CloudSecOps.Web.ViewModels.Admin.AdminDashboardViewModel

@{
    ViewData["Title"] = "Administrator";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="h3 mb-1">Administrator Workspace</h1>
        <p class="text-muted mb-0">Foundation, roles, demo users, and system readiness for Task 1.</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary" asp-action="Users">User and Role Overview</a>
        <a class="btn btn-outline-secondary" asp-action="SystemStatus">Seed Status</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4 col-xl">
        <div class="card h-100">
            <div class="card-body">
                <span class="text-muted small text-uppercase">Users</span>
                <div class="display-6 fw-semibold">@Model.UserCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-xl">
        <div class="card h-100">
            <div class="card-body">
                <span class="text-muted small text-uppercase">Roles</span>
                <div class="display-6 fw-semibold">@Model.RoleCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-xl">
        <div class="card h-100">
            <div class="card-body">
                <span class="text-muted small text-uppercase">Incidents</span>
                <div class="display-6 fw-semibold">@Model.IncidentCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-xl">
        <div class="card h-100">
            <div class="card-body">
                <span class="text-muted small text-uppercase">Assets</span>
                <div class="display-6 fw-semibold">@Model.AssetCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-xl">
        <div class="card h-100">
            <div class="card-body">
                <span class="text-muted small text-uppercase">Vulnerabilities</span>
                <div class="display-6 fw-semibold">@Model.VulnerabilityCount</div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header fw-semibold">Recent Audit Activity</div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Action</th>
                    <th>Entity</th>
                    <th>User</th>
                    <th>Timestamp</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.RecentAuditLogs.Count == 0)
                {
                    <tr>
                        <td colspan="4" class="text-muted">No audit activity has been recorded yet.</td>
                    </tr>
                }
                else
                {
                    @foreach (var log in Model.RecentAuditLogs)
                    {
                        <tr>
                            <td>@log.Action</td>
                            <td>@log.EntityName</td>
                            <td>@log.UserName</td>
                            <td>@log.Timestamp.ToString("u")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
