@model CloudSecOps.Web.ViewModels.Admin.AdminDashboardViewModel

@{
    ViewData["Title"] = "Administrator";
}

<section class="cso-page-header">
    <div>
        <p>Administration</p>
        <h1>Administrator Workspace</h1>
        <span>Foundation, roles, demo users, and system readiness for Task 1.</span>
    </div>
    <div class="form-actions">
        <a class="btn-primary-app" asp-action="Users">User and Role Overview</a>
        <a class="btn-ghost" asp-action="SystemStatus">Seed Status</a>
    </div>
</section>

<section class="metric-grid">
    <article class="metric-card">
        <span>Users</span>
        <strong>@Model.UserCount</strong>
    </article>
    <article class="metric-card">
        <span>Roles</span>
        <strong>@Model.RoleCount</strong>
    </article>
    <article class="metric-card">
        <span>Incidents</span>
        <strong>@Model.IncidentCount</strong>
    </article>
    <article class="metric-card">
        <span>Incident Reports</span>
        <strong>@Model.IncidentReportCount</strong>
    </article>
    <article class="metric-card">
        <span>Assets</span>
        <strong>@Model.AssetCount</strong>
    </article>
    <article class="metric-card">
        <span>Vulnerabilities</span>
        <strong>@Model.VulnerabilityCount</strong>
    </article>
    <article class="metric-card">
        <span>Audit Logs</span>
        <strong>@Model.AuditLogCount</strong>
    </article>
</section>

<section class="cso-panel">
    <h2>Recent Audit Activity</h2>
    <table class="cso-table">
        <thead>
            <tr>
                <th>Action</th>
                <th>Entity</th>
                <th>User</th>
                <th>Timestamp</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.RecentAuditLogs.Count == 0)
            {
                <tr>
                    <td colspan="4">
                        <div class="cso-empty-state">No audit activity has been recorded yet.</div>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var log in Model.RecentAuditLogs)
                {
                    <tr>
                        <td>@log.Action</td>
                        <td>@log.EntityName</td>
                        <td>@log.UserName</td>
                        <td>@log.Timestamp.ToString("u")</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</section>
