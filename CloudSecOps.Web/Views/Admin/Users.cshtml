@model CloudSecOps.Web.ViewModels.Admin.UserRoleOverviewViewModel

@{
    ViewData["Title"] = "User and Role Overview";
}

<section class="cso-page-header">
    <div>
        <p>Administration</p>
        <h1>User and Role Overview</h1>
        <span>Review users and maintain role access for the Task 1 workspace.</span>
    </div>
    <a class="btn-ghost" asp-action="Index">Back to Admin</a>
</section>

@if (TempData["StatusMessage"] is string statusMessage)
{
    <section class="cso-panel">
        <span class="status-pill active">@statusMessage</span>
    </section>
}

<section class="soc-grid">
    <article class="cso-panel">
        <h2>Users</h2>
        <table class="cso-table">
            <thead>
                <tr>
                    <th>Email</th>
                    <th>Name</th>
                    <th>Department</th>
                    <th>Job Title</th>
                    <th>Roles</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>@user.Email</td>
                        <td>@user.FullName</td>
                        <td>@user.Department</td>
                        <td>@user.JobTitle</td>
                        <td>
                            <form asp-action="UpdateUserRoles" method="post" class="role-card-grid">
                                <input type="hidden" name="userId" value="@user.UserId" />
                                @foreach (var role in Model.Roles)
                                {
                                    <label class="status-pill">
                                        <input type="checkbox"
                                               name="selectedRoles"
                                               value="@role"
                                               checked="@user.Roles.Contains(role)" />
                                        @role
                                    </label>
                                }
                                <button class="btn-ghost" type="submit">Save Roles</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </article>

    <aside class="cso-panel">
        <h2>Roles</h2>
        <div class="role-card-grid">
            @foreach (var role in Model.Roles)
            {
                <span class="status-pill active">@role</span>
            }
        </div>
    </aside>
</section>
