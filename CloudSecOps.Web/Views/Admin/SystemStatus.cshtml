@model CloudSecOps.Web.ViewModels.Admin.SystemSeedStatusViewModel

@{
    ViewData["Title"] = "System Seed Status";
}

<section class="cso-page-header">
    <div>
        <p>Administration</p>
        <h1>System Seed Status</h1>
        <span>Basic readiness check for roles and demo users created by existing seeders.</span>
    </div>
    <a class="btn-ghost" asp-action="Index">Back to Admin</a>
</section>

<section class="metric-grid">
    <article class="metric-card">
        <span>Roles Seeded</span>
        <strong>@(Model.RolesSeeded ? "Ready" : "Review")</strong>
    </article>
    <article class="metric-card">
        <span>Demo Users</span>
        <strong>@(Model.DemoUsersSeeded ? "Ready" : "Review")</strong>
    </article>
    <article class="metric-card">
        <span>Demo User Count</span>
        <strong>@Model.DemoUserCount</strong>
    </article>
    <article class="metric-card">
        <span>Total Users</span>
        <strong>@Model.UserCount</strong>
    </article>
    <article class="metric-card">
        <span>Total Roles</span>
        <strong>@Model.RoleCount</strong>
    </article>
    <article class="metric-card">
        <span>Incidents</span>
        <strong>@Model.IncidentCount</strong>
    </article>
    <article class="metric-card">
        <span>Incident Reports</span>
        <strong>@Model.IncidentReportCount</strong>
    </article>
    <article class="metric-card">
        <span>Audit Logs</span>
        <strong>@Model.AuditLogCount</strong>
    </article>
</section>

<section class="cso-panel">
    <h2>Expected Roles</h2>
    <p>@string.Join(", ", Model.ExpectedRoles)</p>
    @if (Model.MissingRoles.Count > 0)
    {
        <p class="text-danger">Missing: @string.Join(", ", Model.MissingRoles)</p>
    }
    else
    {
        <span class="status-pill active">All expected roles are present.</span>
    }
</section>
