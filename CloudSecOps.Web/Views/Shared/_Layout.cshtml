<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CloudSecOps</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CloudSecOps.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-secondary mb-4">
            <div class="container-fluid">
                <a class="navbar-brand fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">CloudSecOps</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (User.IsInRole("SecurityAnalyst"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Analyst" asp-action="Index">Analyst</a></li>
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Incidents" asp-action="Index">Incidents</a></li>
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Assets" asp-action="Index">Assets</a></li>
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Vulnerabilities" asp-action="Index">Vulnerabilities</a></li>
                        }
                        @if (User.IsInRole("Administrator"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Admin" asp-action="Index">Admin</a></li>
                        }
                        @if (User.IsInRole("Reporter"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Reporter" asp-action="Index">Reporter</a></li>
                        }
                        @if (User.IsInRole("Manager"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Manager" asp-action="Index">Manager</a></li>
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Dashboard" asp-action="Index">Dashboard</a></li>
                        }
                        @if (User.IsInRole("Auditor"))
                        {
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="Audit" asp-action="Index">Audit</a></li>
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="AuditLogs" asp-action="Index">Audit Logs</a></li>
                            <li class="nav-item"><a class="nav-link" asp-area="" asp-controller="EvidenceFiles" asp-action="Index">Evidence Files</a></li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="navbar-text me-3">@User.Identity.Name</span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    <button type="submit" class="btn btn-outline-light btn-sm">Sign out</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Login">Sign in</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - CloudSecOps - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
