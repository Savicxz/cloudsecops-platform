@model IReadOnlyList<CloudSecOps.Web.ViewModels.Vulnerabilities.VulnerabilityListItemViewModel>

@{
    ViewData["Title"] = "Vulnerabilities";
}

<div class="cso-page-header">
    <div>
        <h1>Vulnerabilities</h1>
        <p>Track findings, remediation ownership, due dates, and accepted risk.</p>
    </div>
    <a class="btn-primary-app" asp-action="Create">Add Finding</a>
</div>

<section class="cso-panel">
    <table class="cso-table">
        <thead>
            <tr><th>Title</th><th>Severity</th><th>Status</th><th>Due date</th></tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr><td colspan="4"><div class="cso-empty-state">No vulnerabilities have been recorded yet.</div></td></tr>
            }
            else
            {
                @foreach (var vulnerability in Model)
                {
                    <tr>
                        <td>
                            <a class="table-action" asp-action="Details" asp-route-id="@vulnerability.Id">@vulnerability.Title</a>
                        </td>
                        <td><span class="risk-pill @vulnerability.Severity.ToString().ToLowerInvariant()">@vulnerability.Severity</span></td>
                        <td><span class="status-pill">@vulnerability.Status</span></td>
                        <td>@(vulnerability.DueDate?.ToString("dd MMM yyyy") ?? "-")</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</section>
