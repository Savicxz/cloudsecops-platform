@model List<CloudSecOps.Web.Models.Incidents.IncidentReport>

@{
    ViewData["Title"] = "My Incident Reports";
}

<section class="cso-page-header">
    <div>
        <p>Reporter Workspace</p>
        <h1>My Incident Reports</h1>
        <span>Track drafts, submitted reports, and analyst review status.</span>
    </div>

    <a class="btn-primary-app" asp-controller="IncidentReports" asp-action="Create">
        Report New Incident
    </a>
</section>

<section class="cso-panel">
    @if (Model.Count == 0)
    {
        <div class="cso-empty-state">
            <strong>No reports submitted yet.</strong>
            <span>Use Report New Incident when you need the security team to review an issue.</span>
        </div>
    }
    else
    {
        <table class="cso-table">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Severity</th>
                    <th>Affected Asset</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Submitted</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var report in Model)
                {
                    <tr>
                        <td>@report.Title</td>
                        <td>@report.Category</td>
                        <td><span class="risk-pill @report.Severity.ToLowerInvariant()">@report.Severity</span></td>
                        <td>@report.AffectedAsset</td>
                        <td><span class="status-pill">@report.Status</span></td>
                        <td>@report.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>@(report.SubmittedAt?.ToString("dd MMM yyyy") ?? "-")</td>
                        <td>
                            <a class="table-action" asp-controller="IncidentReports" asp-action="Details" asp-route-id="@report.Id">View</a>
                            @if (report.Status == "Draft")
                            {
                                <a class="table-action" asp-controller="IncidentReports" asp-action="Edit" asp-route-id="@report.Id">Edit</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>
